# ============================================================================
# UPI Conversational Analytics - Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual API keys and paths
# 3. Never commit .env to version control (add to .gitignore)
# ============================================================================

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (Optional - for embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Data Paths
DATA_PATH=./data/raw/upi_transactions_2024.csv
PROCESSED_DATA_PATH=./data/processed/
EMBEDDINGS_PATH=./data/embeddings/

# Database Configuration
DUCKDB_PATH=./data/processed/analytics.duckdb

# Vector Store Configuration
VECTOR_STORE_TYPE=chromadb  # Options: chromadb, faiss
VECTOR_STORE_PATH=./data/embeddings/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Configuration
LLM_MODEL=llama3-70b-8192  # Groq model
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# Application Settings
APP_NAME=UPI Analytics Assistant
APP_PORT=8501
DEBUG_MODE=True
LOG_LEVEL=INFO

# Query Configuration
MAX_RETRIEVAL_RESULTS=5
SQL_TIMEOUT_SECONDS=30
CACHE_ENABLED=True

# Security
ENABLE_AUTH=False  # Set to True for production
SECRET_KEY=your_secret_key_here
